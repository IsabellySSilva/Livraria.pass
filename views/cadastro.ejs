<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro de Livros - Livraria PaSS</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <h1>Livraria PaaS</h1>
    <nav>
      <a href="/produtos">Catálogo</a>
      <a href="/cadastro">Cadastrar Livro</a>
    </nav>
  </header>

  <main class="container">
    <section class="card form-card">
      <h2>Cadastro de Livros</h2>
      <p>Adicione novos livros ao catálogo da loja.</p>

      <% if (mensagem) { %>
        <div class="mensagem sucesso"><%= mensagem %></div>
      <% } %>

      <form action="/cadastro" method="POST">
        <label for="titulo">Título</label>
        <input type="text" id="titulo" name="titulo" required placeholder="Ex: Dom Casmurro">

        <label for="autor">Autor</label>
        <input type="text" id="autor" name="autor" required placeholder="Ex: Machado de Assis">

        <label for="preco">Preço</label>
        <input type="number" id="preco" name="preco" required step="0.01" min="0" placeholder="Ex: 39.90">

        <label for="descricao">Descrição</label>
        <textarea id="descricao" name="descricao" rows="4" placeholder="Resumo do livro"></textarea>

        <label for="imagem_url">URL da capa</label>
        <input type="url" id="imagem_url" name="imagem_url" placeholder="https://exemplo.com/capa.jpg">

        <button type="submit">Cadastrar Livro</button>
      </form>
    </section>
  </main>
</body>
</html>

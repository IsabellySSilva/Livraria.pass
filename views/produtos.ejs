<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Catálogo - Livraria PaaS</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <h1>Livraria PaaS</h1>
    <nav>
      <a href="/produtos">Catálogo</a>
      <a href="/cadastro">Cadastrar Livro</a>
    </nav>
  </header>

  <main class="container">
    <section class="hero">
      <h2>Catálogo de Livros</h2>
      <p>Escolha seu próximo livro favorito e finalize a compra no checkout.</p>
      <a class="botao-secundario" href="/cadastro">Cadastrar novo livro</a>
    </section>

    <% if (livros.length === 0) { %>
      <div class="card vazio">
        <h3>Nenhum livro cadastrado ainda.</h3>
        <p>Use a tela de cadastro para adicionar produtos à loja.</p>
      </div>
    <% } %>

    <section class="grid-produtos">
      <% livros.forEach(livro => { %>
        <article class="produto-card">
          <img src="<%= livro.imagem_url || 'https://images.unsplash.com/photo-1512820790803-83ca734da794?q=80&w=600&auto=format&fit=crop' %>" alt="Capa do livro <%= livro.titulo %>">
          <div class="produto-info">
            <h3><%= livro.titulo %></h3>
            <p class="autor">Autor: <%= livro.autor %></p>
            <p class="descricao"><%= livro.descricao || 'Livro disponível para compra.' %></p>
            <p class="preco">R$ <%= Number(livro.preco).toFixed(2).replace('.', ',') %></p>
            <a class="botao" href="/checkout/<%= livro.id %>">Comprar</a>
          </div>
        </article>
      <% }) %>
    </section>
  </main>
</body>
</html>

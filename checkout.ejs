<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout - Livraria PaaS</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <h1>Livraria PaaS</h1>
    <nav>
      <a href="/produtos">Catálogo</a>
      <a href="/cadastro">Cadastrar Livro</a>
    </nav>
  </header>

  <main class="container checkout-layout">
    <section class="card resumo">
      <h2>Resumo da Compra</h2>
      <img src="<%= livro.imagem_url || 'https://images.unsplash.com/photo-1512820790803-83ca734da794?q=80&w=600&auto=format&fit=crop' %>" alt="Capa do livro <%= livro.titulo %>">
      <h3><%= livro.titulo %></h3>
      <p>Autor: <%= livro.autor %></p>
      <p class="preco">Total: R$ <%= Number(livro.preco).toFixed(2).replace('.', ',') %></p>
    </section>

    <section class="card form-card">
      <h2>Checkout</h2>
      <p>Preencha seus dados para finalizar o pedido.</p>

      <% if (mensagem) { %>
        <div class="mensagem sucesso"><%= mensagem %></div>
      <% } %>

      <form action="/checkout/<%= livro.id %>" method="POST">
        <label for="nome_cliente">Nome completo</label>
        <input type="text" id="nome_cliente" name="nome_cliente" required placeholder="Seu nome">

        <label for="email_cliente">E-mail</label>
        <input type="email" id="email_cliente" name="email_cliente" required placeholder="seuemail@exemplo.com">

        <label for="endereco">Endereço de entrega</label>
        <textarea id="endereco" name="endereco" rows="4" required placeholder="Rua, número, bairro, cidade e CEP"></textarea>

        <button type="submit">Finalizar Pedido</button>
      </form>
    </section>
  </main>
</body>
</html>
